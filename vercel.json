{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/((?!api/|assets/).*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, must-revalidate" }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/((?!api/|assets/).*)",
      "destination": "/index.html"
    }
  ],
  "crons": [
    { "path": "/api/cron-reminder?task=tick", "schedule": "0 3 * * *" },
    { "path": "/api/cron-reminder?task=tick", "schedule": "0 15 * * *" }
  ],
  "functions": {
    "api/[route].js": {
      "maxDuration": 60,
      "memory": 512
    },
    "api/ara-chat.js": {
      "maxDuration": 60
    },
    "api/expense-submit.js": {
      "maxDuration": 60,
      "memory": 512
    },
    "api/cron-reminder.js": {
      "maxDuration": 30
    }
  }
}
