{
  "rewrites": [
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "crons": [
    {
      "path": "/api/cron-reminder?task=stock",
      "schedule": "0 1 * * *"
    },
    {
      "path": "/api/cron-reminder?task=reminder",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron-reminder?task=daily",
      "schedule": "0 14 * * *"
    },
    {
      "path": "/api/cron-reminder?task=weekly",
      "schedule": "0 2 * * 0"
    },
    {
      "path": "/api/cron-reminder?task=cleanup",
      "schedule": "0 19 1 * *"
    },
    {
      "path": "/api/cron-reminder?task=wa-cleanup",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/cron-reminder?task=bukti-bayar",
      "schedule": "0 2 * * 1-6"
    },
    {
      "path": "/api/cron-reminder?task=bukti-bayar",
      "schedule": "0 3 * * 1-6"
    },
    {
      "path": "/api/cron-reminder?task=bukti-bayar",
      "schedule": "0 4 * * 1-6"
    },
    {
      "path": "/api/cron-reminder?task=bukti-bayar",
      "schedule": "0 5 * * 1-6"
    },
    {
      "path": "/api/cron-reminder?task=bukti-bayar",
      "schedule": "0 6 * * 1-6"
    },
    {
      "path": "/api/cron-reminder?task=bukti-bayar",
      "schedule": "0 7 * * 1-6"
    },
    {
      "path": "/api/cron-reminder?task=bukti-bayar",
      "schedule": "0 8 * * 1-6"
    },
    {
      "path": "/api/cron-reminder?task=bukti-bayar",
      "schedule": "0 9 * * 1-6"
    },
    {
      "path": "/api/cron-reminder?task=bukti-bayar",
      "schedule": "0 10 * * 1-6"
    },
    {
      "path": "/api/cron-reminder?task=bukti-bayar",
      "schedule": "0 11 * * 1-6"
    },
    {
      "path": "/api/cron-reminder?task=backup",
      "schedule": "0 2 1 * *"
    }
  ],
  "functions": {
    "api/[route].js": {
      "maxDuration": 30,
      "memory": 512
    },
    "api/ara-chat.js": {
      "maxDuration": 60
    },
    "api/cron-reminder.js": {
      "maxDuration": 30
    }
  }
}
