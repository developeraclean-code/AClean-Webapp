{
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "crons": [
    {
      "path": "/api/cron-reminder",
      "schedule": "0 10 * * *"
    },
    {
      "path": "/api/cron-reminder",
      "schedule": "0 11 * * *"
    },
    {
      "path": "/api/cron-reminder",
      "schedule": "0 13 * * 6"
    }
  ]
}
