{
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "crons": [
    {
      "path": "/api/cron-reminder",
      "schedule": "0 10 * * 1-6"
    }
  ],
  "functions": {
    "api/[route].js": {
      "maxDuration": 30,
      "memory": 512
    },
    "api/ara-chat.js": {
      "maxDuration": 60
    },
    "api/cron-reminder.js": {
      "maxDuration": 30
    }
  }
}
