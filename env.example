# Copy file ini menjadi .env.local untuk development lokal
# Di Vercel: tambahkan variabel ini di Settings > Environment Variables
#
# PENTING — JANGAN pernah commit .env.local atau .env.production ke git!
# ─────────────────────────────────────────────────────────────────────
# VITE_* = otomatis di-bundle ke JavaScript public (browser bisa baca)
#          Hanya untuk nilai yang memang boleh publik
# Non-VITE = server-only, tidak pernah sampai ke browser

# ── FRONTEND (Supabase anon key memang public by design) ──
VITE_SUPABASE_URL=https://xxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJxxxxxxxxxxxxxxxx

# ── BACKEND ONLY — jangan pakai prefix VITE_ untuk variabel di bawah ini ──

# Supabase server-side (URL sama, tanpa VITE_ untuk konvensi backend)
SUPABASE_URL=https://xxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJxxxxxxxxxxxxxxxx
SUPABASE_SERVICE_KEY=eyJxxxxxxxxxxxxxxxx

# WhatsApp — server-only, JANGAN pakai VITE_ prefix
FONNTE_TOKEN=your_fonnte_token_here
OWNER_PHONE=628xxxxxxxxxx

# Internal API secret — server-only, JANGAN pakai VITE_ prefix
# Generate: openssl rand -hex 32
INTERNAL_API_SECRET=your_random_64char_hex_here

# Cron secret (untuk Vercel Cron job auth)
CRON_SECRET=your_cron_secret_here

# LLM API keys — server-only
ANTHROPIC_API_KEY=sk-ant-xxx
OPENAI_API_KEY=sk-proj-xxx
GROQ_API_KEY=gsk_xxx

# Cloudflare R2 (image storage) — server-only
R2_ACCESS_KEY=xxx
R2_SECRET_KEY=xxx
R2_ACCOUNT_ID=xxx
R2_BUCKET_NAME=aclean-files
R2_PUBLIC_URL=https://xxx.r2.dev

# Custom domain opsional, untuk CORS allowlist
ALLOWED_ORIGIN=https://your-custom-domain.com
